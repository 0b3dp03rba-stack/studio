
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan super simpel: Asal login, boleh baca dan tulis apa saja.
    // Logika siapa yang boleh akses apa (Admin vs User) dikelola di level aplikasi (Next.js).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
