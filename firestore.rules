
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan super simpel: Asal login, bebas akses.
    // Keamanan role (siapa yang bisa buka menu Admin) ditangani di level aplikasi (NextJS Layout).
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
