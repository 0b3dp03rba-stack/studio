
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan sangat simpel: Asal login (terautentikasi), bebas baca dan tulis.
    // Keamanan level role (Admin vs User) ditangani di level aplikasi/UI.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
