
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Aturan paling simpel: Asal login, bebas akses ke semua dokumen.
    // Tidak ada lagi pengecekan role yang berbelit di level database.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
